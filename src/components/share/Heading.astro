---
import { cn } from '@/lib/utils';

interface Props {
  level?: 1 | 2 | 3 | 4;
  class?: string;
}

const { level = 1, class: className } = Astro.props;

const Tag = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4';
---

<Tag
  class={cn(
    'neo-heading font-display font-black text-main-dark tracking-tighter leading-none',
    className
  )}
>
  <slot />
</Tag>

<style>
  .neo-heading {
    --neo-offset: 5px;
    --neo-color: #000000;
    --neo-stroke: var(--color-main-dark, #000000);

    paint-order: stroke fill;
    -webkit-text-stroke: 1.5px var(--neo-stroke);
    text-shadow:
      var(--neo-offset) var(--neo-offset) 0 var(--neo-color),
      var(--neo-offset) var(--neo-offset) 0 var(--neo-stroke);
  }
</style>
