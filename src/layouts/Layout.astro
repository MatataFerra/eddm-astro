---
import DirtyBackground from '@/components/share/DirtyBackground.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'El Diario de Mati' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | El Diario de Mati</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <DirtyBackground />
    <slot />
  </body>
</html>
